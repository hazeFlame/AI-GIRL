{
	"name": "ai-girl",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"check": "pnpm typecheck && pnpm lint",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply ai-girl --local",
		"db:migrate:remote": "wrangler d1 migrations apply ai-girl --remote",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
	},
	"dependencies": {
		"@ai-sdk/react": "^3.0.184",
		"@base-ui/react": "^1.4.1",
		"@number-flow/react": "^0.6.0",
		"@opennextjs/cloudflare": "^1.19.9",
		"ai": "^6.0.182",
		"better-auth": "^1.6.11",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"framer-motion": "^12.38.0",
		"lucide-react": "^1.16.0",
		"next": "16.2.6",
		"next-themes": "^0.4.6",
		"react": "^19.1.7",
		"react-dom": "^19.1.7",
		"shadcn": "^4.7.0",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19.1.7",
		"@types/react-dom": "^19.1.7",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9",
		"eslint-config-next": "16.2.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.91.0"
	}
}
